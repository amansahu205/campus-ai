# Application
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true

# Database
POSTGRES_USER=campus_ai
POSTGRES_PASSWORD=campus_ai_secret
POSTGRES_DB=campus_ai_dev
DATABASE_URL=postgresql+asyncpg://campus_ai:campus_ai_secret@localhost:5432/campus_ai_dev

# Redis / ARQ
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=campus_ai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Pipeline settings
CONTENT_HASH_ALGORITHM=sha256
SCRAPE_CONCURRENCY=5
LLM_STRUCTURING_TIMEOUT=30

# Confidence routing (RAG)
RAG_HIGH_CONFIDENCE_THRESHOLD=0.75
RAG_LOW_CONFIDENCE_THRESHOLD=0.40
