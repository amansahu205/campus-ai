# ─────────────────────────────────────────────────────────────
# University Intelligence Platform — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development
DEBUG=true

# Database (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/uip
DATABASE_POOL_SIZE=10

# Redis (ARQ queues + rate limiting)
REDIS_URL=redis://localhost:6379

# Qdrant (vector store for RAG)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # Required in prod; leave blank for local Docker
QDRANT_COLLECTION=uip_chunks

# OpenAI (GPT-4o structuring + embeddings + RAG generation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Claude fallback — optional)
ANTHROPIC_API_KEY=                      # Optional

# RAG settings
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD_CONFIDENT=0.85
RAG_SIMILARITY_THRESHOLD_UNCERTAIN=0.75
RAG_RATE_LIMIT_PER_HOUR=30

# Admin (HTTP Basic Auth for /admin/* routes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-in-prod         # Change before any deployment

# CORS (comma-separated origins, e.g. https://campusai.vercel.app)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Trusted hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Supported universities (must match URL slugs)
SUPPORTED_UNIVERSITIES=umd,michigan

# Prefect (pipeline orchestration — Cloud URL in prod)
PREFECT_API_URL=                        # e.g. https://api.prefect.cloud/api/accounts/xxx

# Observability
SENTRY_DSN=                             # Optional; get from sentry.io

# Cloudflare R2 (v1.1 — raw scrape archive)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
